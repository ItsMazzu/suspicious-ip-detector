# ─────────────────────────────────────────────────────────────
# SIEM Simulator — Variáveis de ambiente
# ─────────────────────────────────────────────────────────────
# Copie este arquivo como .env e preencha os valores reais.
# NUNCA commite o arquivo .env no controle de versão.
# ─────────────────────────────────────────────────────────────

# Nível de log: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Diretório de saída dos logs (padrão: data/logs/)
# LOG_DIR=data/logs

# Chave da API ip-api.com Pro (opcional — versão gratuita não requer chave)
# Com a chave Pro, o sistema usa HTTPS e não tem limite de 45 req/min.
# IPAPI_KEY=sua_chave_aqui

# Timeout para requisições de geolocalização (segundos)
GEO_REQUEST_TIMEOUT=6
